#!/bin/bash
set -e

# ==============================================================================
# GLOBAL CONFIG
# ==============================================================================

START_VMID=5001
BRIDGE="vmbr0"
GATEWAY="192.168.80.1"
STORAGE="local-lvm"
TZ="America/New_York"

# --- VPN ---
PIA_USER="p1234567"
PIA_PASS="YourPIAPassword"

# --- ALERT WEBHOOKS ---
DISCORD_WEBHOOK="https://discord.com/api/webhooks/XXXX"
TEAMS_WEBHOOK="https://outlook.office.com/webhook/XXXX"

# --- Cloudflare ---
CF_TOKEN="REPLACE_WITH_YOURS"

# ==============================================================================
# APPS
# ==============================================================================

declare -A APPS=(
  ["downloads"]="192.168.80.205/24:docker"
  ["media"]="192.168.80.200/24:docker"
  ["monitor"]="192.168.80.220/24:docker"
  ["cloudflared"]="192.168.80.215/24:docker"
)

ORDERED_APPS=(downloads media monitor cloudflared)
CURRENT_ID=$START_VMID

# ==============================================================================
# HELPERS
# ==============================================================================

log(){ echo "[INFO] $1"; }

create_container() {
  pct create $CURRENT_ID local:vztmpl/alpine-3.20-default_amd64.tar.xz \
    -hostname $1 \
    -net0 name=eth0,bridge=$BRIDGE,ip=$2,gw=$GATEWAY \
    -rootfs $STORAGE:4 \
    -memory 2048 -cores 2 \
    -features nesting=1

  pct start $CURRENT_ID
  sleep 5

  pct exec $CURRENT_ID -- apk add docker curl bash
  pct exec $CURRENT_ID -- rc-update add docker default
  pct exec $CURRENT_ID -- service docker start
}

# ==============================================================================
# DOWNLOAD STACK (VPN + FAILOVER + ALERTING)
# ==============================================================================

deploy_downloads() {

pct exec $CURRENT_ID -- mkdir -p /opt/downloads

pct exec $CURRENT_ID -- docker run -d \
  --name gluetun \
  --cap-add=NET_ADMIN \
  --device /dev/net/tun \
  -e VPN_SERVICE_PROVIDER=privateinternetaccess \
  -e OPENVPN_USER="$PIA_USER" \
  -e OPENVPN_PASSWORD="$PIA_PASS" \
  -e SERVER_COUNTRIES="United States,Sweden,Netherlands" \
  -e SERVER_SELECTION_STRATEGY=latency \
  -e FIREWALL=on \
  -e TZ=$TZ \
  -p 8080:8080 \
  -p 8081:8081 \
  -p 9999:9999 \
  --restart unless-stopped \
  qmcgaw/gluetun

sleep 10

# qBittorrent
pct exec $CURRENT_ID -- docker run -d \
  --name qbittorrent \
  --network container:gluetun \
  -e WEBUI_PORT=8080 \
  -v /opt/downloads/qbt:/config \
  --restart unless-stopped \
  lscr.io/linuxserver/qbittorrent

# SABnzbd
pct exec $CURRENT_ID -- docker run -d \
  --name sabnzbd \
  --network container:gluetun \
  -v /opt/downloads:/downloads \
  --restart unless-stopped \
  lscr.io/linuxserver/sabnzbd

# -------------------------
# ALERTING SCRIPT
# -------------------------

pct exec $CURRENT_ID -- sh -c "cat << 'EOF' > /alert.sh
#!/bin/sh

STATUS=\$(wget -qO- http://localhost:9999/v1/openvpn/status | grep -i 'connected')

if [ -z \"\$STATUS\" ]; then
  MSG=\"🚨 VPN DOWN on $(hostname)\"

  curl -H 'Content-Type: application/json' \
       -d \"{\\\"content\\\": \\\"\$MSG\\\"}\" \
       $DISCORD_WEBHOOK

  curl -H 'Content-Type: application/json' \
       -d \"{\\\"text\\\": \\\"\$MSG\\\"}\" \
       $TEAMS_WEBHOOK
fi
EOF"

pct exec $CURRENT_ID -- chmod +x /alert.sh
pct exec $CURRENT_ID -- sh -c "echo '*/2 * * * * /alert.sh' | crontab -"
}

# ==============================================================================
# MEDIA STACK
# ==============================================================================

deploy_media() {

pct exec $CURRENT_ID -- docker run -d \
  --name jellyfin -p 8096:8096 \
  --restart unless-stopped jellyfin/jellyfin

pct exec $CURRENT_ID -- docker run -d \
  --name seerr -p 5055:5055 \
  --restart unless-stopped fallenbagel/jellyseerr
}

# ==============================================================================
# MONITORING STACK
# ==============================================================================

deploy_monitor() {

pct exec $CURRENT_ID -- mkdir -p /opt/monitor

# Prometheus config
pct exec $CURRENT_ID -- sh -c "cat << 'EOF' > /opt/monitor/prometheus.yml
global:
  scrape_interval: 5s
scrape_configs:
  - job_name: gluetun
    static_configs:
      - targets: ['192.168.80.205:9999']
EOF"

# Prometheus
pct exec $CURRENT_ID -- docker run -d \
  --name prometheus \
  -p 9090:9090 \
  -v /opt/monitor:/etc/prometheus \
  prom/prometheus

# Grafana
pct exec $CURRENT_ID -- docker run -d \
  --name grafana \
  -p 3000:3000 \
  -e GF_SECURITY_ADMIN_PASSWORD=admin \
  grafana/grafana
}

# ==============================================================================
# CLOUDFLARE
# ==============================================================================

deploy_cf() {
pct exec $CURRENT_ID -- docker run -d \
  --name cloudflared \
  --network host \
  cloudflare/cloudflared \
  tunnel run --token $CF_TOKEN
}

# ==============================================================================
# MAIN LOOP
# ==============================================================================

for APP in "${ORDERED_APPS[@]}"; do

IP=$(echo ${APPS[$APP]} | cut -d':' -f1)

create_container $APP $IP

case $APP in
  downloads) deploy_downloads ;;
  media) deploy_media ;;
  monitor) deploy_monitor ;;
  cloudflared) deploy_cf ;;
esac

((CURRENT_ID++))

done

echo "✅ FULL STACK WITH VPN + ALERTING DEPLOYED"
